      <aliases enabled='yes' />
      <column caption='Delivery Performance Classification' datatype='string' name='[Calculation_1385153722052608]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN &quot;Fast&quot; ELSE &quot;Delayed&quot; END' />
      </column>
      <column caption='Loss-Making Orders Identification' datatype='string' name='[Calculation_1385153723256833]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN &quot;Loss&quot; ELSE &quot;Profit&quot; END' />
      </column>
      <column caption='City-Level Benchmarking' datatype='real' name='[Calculation_1385153726636034]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City] : AVG([Sales]) }' />
      </column>
      <column caption='Product Detail Impact' datatype='real' name='[Calculation_1385153727430659]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG({ INCLUDE [Product_Name] : SUM([Sales]) })' />
      </column>
